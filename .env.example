# =============================================================================
# B2B Stickers & Labels Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For production (Railway/Vercel), set these in the platform dashboard.
#
# REQUIRED = App won't start without these
# CORE     = Required for core business features
# OPTIONAL = Nice to have, features degrade gracefully without them
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE (REQUIRED)
# -----------------------------------------------------------------------------
# Railway provides this automatically. Format: postgresql+asyncpg://user:pass@host:port/db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/b2b_stickers

# -----------------------------------------------------------------------------
# REDIS / CELERY (REQUIRED)
# -----------------------------------------------------------------------------
# Railway Redis provides this. Used for caching, Celery broker, and result backend.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# AUTHENTICATION (REQUIRED)
# -----------------------------------------------------------------------------
# JWT_SECRET: Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-minimum-32-characters-long

# ADMIN_PASSWORD_HASH: bcrypt hash of your admin password.
# Generate with: cd apps/api && python scripts/hash_password.py "your-password"
ADMIN_PASSWORD_HASH=

# Magic link base URL for customer authentication
MAGIC_LINK_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# STRIPE (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Create a subscription product in Stripe Dashboard, then copy the product ID
STRIPE_SUBSCRIPTION_PRODUCT_ID=prod_...

# Subscribe & Save discount percentage
SUBSCRIBE_AND_SAVE_DISCOUNT_PERCENT=10

# -----------------------------------------------------------------------------
# EMAIL (CORE)
# -----------------------------------------------------------------------------
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=B2B Stickers <hello@b2b-stickers.co.uk>

# SMTP fallback (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# -----------------------------------------------------------------------------
# VAT (CORE — UK B2B)
# -----------------------------------------------------------------------------
VAT_RATE_PERCENT=20.0
VAT_NUMBER=GB123456789

# -----------------------------------------------------------------------------
# APP URLs (REQUIRED for production)
# -----------------------------------------------------------------------------
# Update these after deploying each service
API_BASE_URL=http://localhost:8000
DASHBOARD_BASE_URL=http://localhost:3001
SITE_BASE_URL=http://localhost:3000

# Environment: development | staging | production
ENV=development

# -----------------------------------------------------------------------------
# AI GENERATION (OPTIONAL)
# -----------------------------------------------------------------------------
# Replicate API token: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# OpenAI API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# FILE STORAGE (OPTIONAL)
# -----------------------------------------------------------------------------
# AWS S3 for product images
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
S3_BUCKET=

# Or Cloudflare R2 (alternative to S3)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# -----------------------------------------------------------------------------
# PRINT FULFILLMENT (OPTIONAL)
# -----------------------------------------------------------------------------
# Prodigi API key for print-on-demand fulfillment
PRODIGI_API_KEY=

# -----------------------------------------------------------------------------
# COMPANY VERIFICATION (OPTIONAL)
# -----------------------------------------------------------------------------
# Companies House API key: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=

# -----------------------------------------------------------------------------
# MARKETPLACE INTEGRATIONS (OPTIONAL)
# -----------------------------------------------------------------------------
# Amazon Selling Partner API
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_MARKETPLACE_ID=A1F83G8C2ARO7P

# eBay Developer Program
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REFRESH_TOKEN=
EBAY_MARKETPLACE=EBAY_GB

# -----------------------------------------------------------------------------
# MONITORING (OPTIONAL)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking: https://sentry.io/settings/projects/
SENTRY_DSN=
